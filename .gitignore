# ============================================================
# CPG Analytics Dashboard — .gitignore
# ============================================================

# --- Secrets & Keys ---
.env
.env.local
.env.*.local
*.key
*.pem
.encryption.key
credentials.*
secrets.*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/build/
.pnp
.pnp.js

# --- Data Files ---
*.db
*.pkl
*.h5
*.joblib
data/kaggle/*.csv
data/kaggle/*.zip
data/kaggle/images/
data/kaggle/rossmann/
data/raw/
data/processed/
# Customer analytics pilot — Telco Churn dataset (~170KB, re-downloadable via kaggle CLI)
data/customer-analytics/*.csv
data/customer-analytics/*.zip

# --- Kaggle credentials (defensive — should be in ~/.kaggle/, never in repo) ---
kaggle.json
.kaggle/

# --- Stray browser-tool artifacts (screenshots taken into repo root by external MCPs) ---
# Real committed screenshots live under docs/screenshots/.
cpg-*.png
.playwright-mcp/
frontend/test-results/
frontend/playwright-report/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Docker ---
docker-compose.override.yml

# --- MLflow ---
mlruns/
mlartifacts/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
logs/
*.log
*.log.*

# --- Coverage ---
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- Temp ---
tmp/
temp/
*.tmp
*.bak
*.bak2
*.old

# --- IDE / external AI assistant tool-local dirs ---
.codersinflow/
.codex/
.cursor/
.islstudio/
.vibecheck/
.next/
out/
*.vsix

# --- Python venv (project's actual venv lives outside the repo) ---
.venv/

# --- Local Claude Code overrides (settings.local.json is convention-local) ---
.claude/settings.local.json

# --- Stray browser-tool artifacts at repo root (real screenshots live under docs/screenshots/) ---
# Root-anchored so docs/screenshots/holy/*.png remain trackable.
/holy-*.png

# --- Agent supervisor runtime state (any depth, not just repo root) ---
# Drills sometimes use cwd=backend so data/ ends up at backend/data/
data/agent-supervisor/
**/data/agent-supervisor/

# --- Eval scratch dirs (drill outputs, diagnostics) ---
data/eval/
**/data/eval/

# --- Kaggle supply-chain dataset (39MB, re-downloadable via kaggle CLI) ---
data/kaggle/supply-chain/

# --- BMad personal config (per-user; regenerated by `scripts/bmad.sh install`) ---
# BMad's own _bmad/custom/.gitignore also excludes *.user.toml — we mirror it
# here so cloners don't accidentally commit another user's preferences.
_bmad/config.user.toml
_bmad/**/config.user.toml

# --- Approval-rules backups (global §69) ---
# settings.local.json is per-clone; backups are per-rewrite — never commit.
.claude/settings.local.json.bak.*
.codersinflow
.vscode
node_modules
.venv
.codex
out
dist
.claude
CLAUDE.md
.git
__pycache__
*.pyc
.next
# .github was fully ignored from initial scaffold 842fe473 — stale rule:
# 3 workflows (audits.yml, contracts.yml, loadtest.yml) are already tracked.
# Narrowed to ignore only secret-bearing patterns (per §47.6 + §4.6).
.github/secrets/
.github/credentials*
.github/.env*

# Project rename state (managed by scripts/rename_project.sh)
.project-state

# Phase 100 autonomous-build runtime state (per-clone)
.phase100-build-state


# --- Insurance project (2026-06-01) — Kaggle data re-downloadable via scripts/download_insurance_datasets.py ---
data/insurance/**/*.csv
data/insurance/**/*.zip

# Audit reports + logs (re-generated per cron run)
jobs/reports/
jobs/logs/

# RAG generated indexes (regenerated by cron)
data/rag/chunks/
data/rag/embeddings/
data/rag/*.db

# §21 prompt-tracker · DB excluded (markdown backup tracked)
data/prompts.db
data/prompts.db-shm
data/prompts.db-wal

# Tools cloned via integration sweeps (not part of insur source)
ComfyUI/
frontend/OmniParser/

# Dispatcher pending-fix proposals (transient · archive only)
.agent/pending_*.diff
.agent/archive/

# §50 dispatcher .py.txt backup mirrors (transient · audit logs only)
*.py.txt

# Runtime data dirs (transient state · not source)
data/prompts/
data/test_reports/

# Runtime ML model weights + jobs state
yolov8n.pt
jobs/state/
jobs/automation/plan-*.md

# Hourly cron timestamp-only churn (per §57.7 · committed value = audit results in jobs/reports/insurance/)
data/work_tracker/insurance_alignment.json
