#!/usr/bin/env bash
# voice-diagnose — find out why voice capture isn't working.
# Specifically checks: mic detected? mic unmuted? volume reasonable?
# whisper installed? clipboard tool working?

set -uo pipefail

red()    { printf "\033[1;31m✗ %s\033[0m\n" "$*"; }
green()  { printf "\033[1;32m✓ %s\033[0m\n" "$*"; }
yellow() { printf "\033[1;33m⚠ %s\033[0m\n" "$*"; }
blue()   { printf "\n\033[1;34m▸ %s\033[0m\n" "$*"; }

# 1. arecord devices
blue "1. Capture devices visible to arecord"
if arecord -l 2>&1 | grep -q "card "; then
    arecord -l | grep "card " | head -5
    green "arecord sees a mic"
else
    red "no arecord devices — sudo apt install alsa-utils"
    exit 1
fi

# 2. ALSA mixer — show mic mute state + volume
blue "2. ALSA mixer state (mic mute? volume?)"
if command -v amixer >/dev/null 2>&1; then
    # Try several common control names
    for ctrl in "Capture" "Mic" "Mic Boost" "Internal Mic" "Front Mic"; do
        out=$(amixer get "$ctrl" 2>/dev/null | grep -E "%|Mono:" | head -2)
        if [[ -n "$out" ]]; then
            echo "  [$ctrl]"
            echo "$out" | sed 's|^|    |'
        fi
    done
    yellow "if mic shows [off] or very low %, fix with: alsamixer"
fi

# 3. PulseAudio default source
blue "3. PulseAudio / PipeWire default input"
if command -v pactl >/dev/null 2>&1; then
    default_src=$(pactl info 2>/dev/null | grep "Default Source" | cut -d: -f2 | xargs)
    if [[ -n "$default_src" ]]; then
        green "default source: $default_src"
        pactl list sources short 2>/dev/null | head -5
        # Show source volume
        pactl get-source-volume "@DEFAULT_SOURCE@" 2>&1 | head -1
        pactl get-source-mute "@DEFAULT_SOURCE@" 2>&1 | head -1
    else
        yellow "PulseAudio not running OR no default source — try: pulseaudio --start"
    fi
fi

# 4. Live 3-second test — show actual volume detected
blue "4. Live capture test (3s) — speak loudly!"
WAV="/tmp/diag_$$.wav"
sleep 1  # give them a moment
echo "  ▶ recording NOW (3 sec)..."
arecord -q -f S16_LE -r 16000 -c 1 -d 3 "$WAV" 2>&1
if [[ -f "$WAV" ]]; then
    MAX=$(ffmpeg -i "$WAV" -af volumedetect -vn -sn -dn -f null /dev/null 2>&1 | \
        grep "max_volume" | awk '{print $5}' | tr -d -)
    MEAN=$(ffmpeg -i "$WAV" -af volumedetect -vn -sn -dn -f null /dev/null 2>&1 | \
        grep "mean_volume" | awk '{print $5}' | tr -d -)
    echo "  max_volume: -${MAX:-?}dB  mean_volume: -${MEAN:-?}dB"
    if [[ -n "$MAX" ]] && (( $(echo "$MAX > 60" | bc -l 2>/dev/null) )); then
        red "audio is SILENT (max -${MAX}dB) — mic muted or volume = 0"
        yellow "fix: run 'alsamixer', press F4 to show capture, unmute (M) + raise volume"
        yellow "or:  pactl set-source-mute @DEFAULT_SOURCE@ 0"
        yellow "     pactl set-source-volume @DEFAULT_SOURCE@ 75%"
    elif [[ -n "$MAX" ]] && (( $(echo "$MAX > 30" | bc -l 2>/dev/null) )); then
        yellow "audio is QUIET (max -${MAX}dB) — turn up mic or speak louder"
    else
        green "audio level OK (max -${MAX}dB) — mic working"
    fi
    rm -f "$WAV"
fi

# 5. STT tools installed?
blue "5. STT + clipboard tooling"
PY="/media/praveen/praveenlinux21/praveen/aman/cuda/venv/bin/python"
if [[ -x "$PY" ]]; then
    if "$PY" -c "import whisper" 2>/dev/null; then green "whisper installed"; else red "whisper missing"; fi
    if "$PY" -c "import faster_whisper" 2>/dev/null; then green "faster-whisper installed"; else yellow "faster-whisper missing (optional)"; fi
fi
command -v xclip >/dev/null && green "xclip installed" || yellow "xclip missing"
command -v wl-copy >/dev/null && green "wl-copy installed" || yellow "wl-copy missing"

blue "Done."
echo "If mic is silent, fix with: alsamixer (F4 → capture → M to unmute → arrow up)"
echo "Then run: bash scripts/voice"
