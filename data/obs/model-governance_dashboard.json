{
  "title": "Model Governance \u00b7 model-governance \u00b7 production dashboard",
  "panels": [
    {
      "id": 1,
      "title": "Predictions/sec",
      "type": "graph",
      "query": "rate(model-governance_predictions_total[5m])"
    },
    {
      "id": 2,
      "title": "p95 Latency",
      "type": "graph",
      "query": "histogram_quantile(0.95, rate(model-governance_latency_bucket[5m]))"
    },
    {
      "id": 3,
      "title": "Accuracy (Live)",
      "type": "gauge",
      "query": "avg(model-governance_accuracy)"
    },
    {
      "id": 4,
      "title": "Drift PSI",
      "type": "graph",
      "query": "model-governance_drift_psi"
    },
    {
      "id": 5,
      "title": "Fairness DI by Age",
      "type": "gauge",
      "query": "model-governance_fairness_di_age"
    },
    {
      "id": 6,
      "title": "Error Rate",
      "type": "graph",
      "query": "rate(model-governance_errors_total[5m])"
    },
    {
      "id": 7,
      "title": "HITL Escalations",
      "type": "graph",
      "query": "rate(model-governance_hitl_total[5m])"
    },
    {
      "id": 8,
      "title": "Cost/Request ($)",
      "type": "graph",
      "query": "rate(model-governance_cost_usd[5m])"
    }
  ],
  "alerts": [
    {
      "name": "accuracy_below_0.85",
      "expr": "model-governance_accuracy < 0.85"
    },
    {
      "name": "drift_psi_above_0.2",
      "expr": "model-governance_drift_psi > 0.2"
    },
    {
      "name": "error_rate_above_5pct",
      "expr": "rate(model-governance_errors_total[5m]) > 0.05"
    }
  ],
  "refresh": "30s",
  "spec": "\u00a7138 observability"
}