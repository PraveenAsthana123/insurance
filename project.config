# project.config — SINGLE SOURCE OF TRUTH for project identity.
#
# Three identifiers control everything else in the codebase:
#
#   PROJECT_SLUG          short codename (lowercase + _ only).
#                         Drives: container names, DB user/dbname,
#                         file-name prefixes (bev-*.png), docker
#                         image tags, package.json "name".
#
#   PROJECT_NAME          human-readable full name.
#                         Drives: READMEs, doc titles, header
#                         h1, page <title>.
#
#   PROJECT_WEBSITE_NAME  short display name.
#                         Drives: browser tab, sidebar logo text,
#                         email subjects, short references.
#
# To rebrand:
#   1. Edit the three lines below.
#   2. Run: scripts/rename_project.sh apply
#   3. Rebuild: docker compose build && cd frontend && npm install
#
# The rename script reads the CURRENT values stored in
# .project-state (auto-maintained), compares against this file,
# and applies the diff atomically.

PROJECT_SLUG=insur
PROJECT_NAME=Insur Analytics Dashboard
PROJECT_WEBSITE_NAME=Insur Analytics
