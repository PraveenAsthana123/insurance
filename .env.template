# ============================================================
# CPG Analytics Dashboard — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insur_analytics
POSTGRES_USER=insur_user
POSTGRES_PASSWORD=changeme_strong_password

# --- Redis (Celery broker & result backend) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PROJECT_API_KEY=
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8001
# Per Phase 2.4 of docs/AUDIT_FIX_PLAN.md — API request timeout (ms).
VITE_API_TIMEOUT_MS=10000

# --- Kaggle (for Rossmann + other flagship datasets) ---
# Get credentials from https://www.kaggle.com/settings/account -> "Create New Token"
# Download kaggle.json, then either place it at ~/.kaggle/kaggle.json
# or set these env vars:
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Ollama (RAG / AI explanations via MCP + agent fleet) ---
OLLAMA_HOST=http://localhost:11434
BASE_MODEL=gemma3:1b
KIVI_MODEL=kivi:local
AGENT_MODEL=kivi:local
COUNCIL_AUTHOR_MODEL=kivi:local
COUNCIL_REVIEWER_MODEL=kivi:local
COUNCIL_CHAIR_MODEL=kivi:local
SIMPLE_AGENTS=100
COUNCIL_AGENTS=5
TASKS=100

# --- Agent platform — Playwright CUA execution ---
# Comma-separated prefix allowlist for /api/v1/agent-platform/cua/execute when
# adapter='playwright' and dry_run=false. Off-allowlist targets return blocked.
PLAYWRIGHT_ALLOWLIST=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
# Per-execution §38.3 audit row destination (JSONL, append-only).
CUA_AUDIT_PATH=data/agent-supervisor/cua_runs.jsonl

# --- Encryption ---
# Fernet key for encrypting secrets in DB (auto-generated on first run if absent)
ENCRYPTION_KEY=

# --- Application ---
LOG_LEVEL=INFO
# Set to "production" to enforce API key authentication
APP_ENV=development

# --- Rate Limiting ---
# Requests per minute per IP on API endpoints
PROJECT_RATE_LIMIT=100
