#!/usr/bin/env bash
# voice — push-to-talk: capture mic → whisper → clipboard.
#
# Uses parecord with the EXPLICIT mic source (PulseAudio/PipeWire default
# source is often the speaker monitor — that's why arecord captures silence).
#
# Usage:
#   bash scripts/voice            # 5s record, base model
#   bash scripts/voice 10         # 10s record
#   bash scripts/voice 5 small    # use whisper-small (better, larger)

set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="${PYTHON:-/media/praveen/praveenlinux21/praveen/aman/cuda/venv/bin/python}"
DURATION="${1:-5}"
MODEL="${2:-base}"

WAV="/tmp/voice_$$_$(date +%s).wav"
TXT="/tmp/voice_$$_$(date +%s).txt"

# ─── find a real mic source (skip monitor / output devices) ─────────────
find_mic_source() {
    if command -v pactl >/dev/null 2>&1; then
        pactl list sources short 2>/dev/null | \
            awk '$2 ~ /^alsa_input\./ {print $2; exit}'
    fi
}

MIC_SRC="${VOICE_MIC_SOURCE:-$(find_mic_source)}"

# ─── 1. record ──────────────────────────────────────────────────────────
printf "\n\033[1;34m🎤 recording ${DURATION}s — speak now...\033[0m\n"

if [[ -n "$MIC_SRC" ]] && command -v parecord >/dev/null 2>&1; then
    printf "    via PulseAudio source: %s\n" "$MIC_SRC"
    parecord --device="$MIC_SRC" --record --rate=16000 --channels=1 \
        --format=s16le --file-format=wav "$WAV" &
    PA_PID=$!
    sleep "$DURATION"
    kill "$PA_PID" 2>/dev/null
    wait "$PA_PID" 2>/dev/null
else
    printf "    via arecord hw:1,0 (stereo, will downmix)\n"
    arecord -q -D hw:1,0 -f S16_LE -r 16000 -c 2 -d "$DURATION" "$WAV"
fi

if [[ ! -s "$WAV" ]]; then
    printf "\033[1;31m✗ recording failed (no audio captured)\033[0m\n"
    printf "\033[1;33m   try: bash scripts/voice-diagnose\033[0m\n"
    exit 1
fi

SIZE=$(du -h "$WAV" | cut -f1)
printf "\033[1;32m✓ recorded ($SIZE)\033[0m\n"

# Check volume
MAX=$(ffmpeg -i "$WAV" -af volumedetect -vn -sn -dn -f null /dev/null 2>&1 | \
    grep "max_volume" | awk '{print $5}' | tr -d -)
if [[ -n "$MAX" ]] && (( $(echo "$MAX > 60" | bc -l 2>/dev/null) )); then
    printf "\033[1;33m⚠ recording is quiet (max -${MAX}dB) — speak louder or check mic\033[0m\n"
    printf "\033[1;33m   diagnose: bash scripts/voice-diagnose\033[0m\n"
fi

# ─── 2. transcribe ──────────────────────────────────────────────────────
printf "\n\033[1;34m📝 transcribing with whisper-${MODEL}...\033[0m\n"

"$PYTHON" - "$WAV" "$MODEL" "$TXT" <<'PYEOF'
import sys, warnings
warnings.filterwarnings("ignore")
wav, model_name, out = sys.argv[1], sys.argv[2], sys.argv[3]
import whisper
model = whisper.load_model(model_name)
result = model.transcribe(wav, fp16=False)
text = result["text"].strip()
with open(out, "w") as f:
    f.write(text)
print(text or "(empty — silence detected)")
PYEOF

TEXT="$(cat "$TXT")"

# ─── 3. clipboard ───────────────────────────────────────────────────────
printf "\n\033[1;34m📋 copying to clipboard...\033[0m\n"
if command -v wl-copy >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    printf '%s' "$TEXT" | wl-copy
    printf "\033[1;32m✓ in clipboard (wl-copy) — paste with Ctrl+V\033[0m\n"
elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$TEXT" | xclip -selection clipboard
    printf "\033[1;32m✓ in clipboard (xclip) — paste with Ctrl+V\033[0m\n"
fi

printf '\a'

# ─── 4. highly-visible result ───────────────────────────────────────────
printf "\n"
printf "\033[1;36m╔════ TRANSCRIPT ════════════════════════════════════════════════╗\033[0m\n"
printf "\033[1;36m║\033[0m %s\n" "$TEXT"
printf "\033[1;36m╚════════════════════════════════════════════════════════════════╝\033[0m\n"
printf "\nfile: %s\n" "$TXT"

rm -f "$WAV"
