#!/usr/bin/env bash
# voice-test ‚ÄĒ one-command end-to-end test you run yourself + speak.
#
# This proves WHETHER your mic + the whole pipeline works for YOU.
# Auto-detects ALL mic sources, records from each, transcribes each,
# tells you which one works.
#
# Usage: bash scripts/voice-test
#   (then speak when prompted)

set -uo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="${PYTHON:-/media/praveen/praveenlinux21/praveen/aman/cuda/venv/bin/python}"

red()    { printf "\033[1;31m%s\033[0m\n" "$*"; }
green()  { printf "\033[1;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[1;33m%s\033[0m\n" "$*"; }
blue()   { printf "\n\033[1;34m‚ēź‚ēź‚ēź %s ‚ēź‚ēź‚ēź\033[0m\n" "$*"; }

blue "Step 1: List ALL input devices (PulseAudio + raw ALSA)"
echo "PulseAudio sources:"
pactl list sources short 2>/dev/null | awk '$2 ~ /^alsa_input\./ && $2 !~ /\.monitor$/ {print "  " $2}'
if pactl list sources short 2>/dev/null | grep -q "echo-cancel-source"; then
    green "  ‚úď echo-cancel-source available (preferred)"
fi
echo
echo "Raw ALSA cards:"
arecord -l 2>&1 | grep "card " | sed 's/^/  /'

blue "Step 2: Record 5 sec ‚ÄĒ you MUST SPEAK during this!"
yellow "  ‚ö† When you see '‚ĖļRECORDING NOW‚óĄ', say something out loud."
yellow "  ‚ö† Say: 'testing one two three four five'"
echo

for src in $(pactl list sources short 2>/dev/null | awk '$2 ~ /^alsa_input\./ && $2 !~ /\.monitor$/ {print $2}'); do
    WAV=/tmp/test_${src##*.}.wav
    printf "\n‚Üí recording from: %s\n" "$src"
    sleep 1
    for i in 3 2 1; do printf "    starting in %d...\r" "$i"; sleep 1; done
    printf "    \033[1;36m‚ĖļRECORDING NOW‚óĄ\033[0m (5 sec ‚ÄĒ SPEAK NOW!)\n"

    parecord --device="$src" --record --rate=16000 --channels=1 \
        --format=s16le --file-format=wav "$WAV" &
    PID=$!
    sleep 5
    kill $PID 2>/dev/null
    wait 2>/dev/null

    SIZE=$(du -h "$WAV" 2>/dev/null | cut -f1)
    MAX=$(ffmpeg -i "$WAV" -af volumedetect -vn -sn -dn -f null /dev/null 2>&1 | grep "max_volume" | awk '{print $5}')
    MEAN=$(ffmpeg -i "$WAV" -af volumedetect -vn -sn -dn -f null /dev/null 2>&1 | grep "mean_volume" | awk '{print $5}')

    echo "  size: $SIZE  max: $MAX  mean: $MEAN"

    # Strip the dB sign for comparison
    MAX_ABS=${MAX#-}
    MAX_ABS=${MAX_ABS%dB}
    MAX_ABS=${MAX_ABS%.*}

    if [[ -z "$MAX_ABS" ]] || (( MAX_ABS > 60 )); then
        red "  ‚úó silent (max ${MAX}) ‚ÄĒ this source captured nothing"
    else
        green "  ‚úď AUDIO CAPTURED at ${MAX}"

        # Transcribe it
        echo "  transcribing..."
        TEXT=$("$PYTHON" - "$WAV" 2>&1 <<'PYEOF'
import sys, warnings
warnings.filterwarnings("ignore")
try:
    from faster_whisper import WhisperModel
    m = WhisperModel("base", device="cpu", compute_type="int8")
    segs, info = m.transcribe(sys.argv[1], language="en", beam_size=5)
    text = " ".join(s.text for s in segs).strip()
    print(text or "(no speech detected)")
except Exception as e:
    print(f"FAIL: {e}")
PYEOF
)
        printf "  \033[1;36mtranscript:\033[0m %s\n" "$TEXT"

        if [[ -n "$TEXT" && "$TEXT" != "(no speech detected)" && "$TEXT" != FAIL:* ]]; then
            green "  ‚ėÖ WORKING SOURCE: $src"
            green "    use this in voice-pro:"
            green "      VOICE_MIC_SOURCE=$src bash scripts/voice-pro"
        fi
    fi
    rm -f "$WAV"
done

blue "Step 3: Summary"
echo "If NO source captured audio:"
yellow "  ‚Üí your mic is muted at OS level or wrong default"
yellow "  ‚Üí open 'pavucontrol' ‚Üí Input Devices tab ‚Üí unmute + raise volume"
yellow "  ‚Üí OR run: pactl set-source-volume <source> 75%"
echo
echo "If sources captured audio but transcript is empty / wrong:"
yellow "  ‚Üí speak LOUDER / closer to mic"
yellow "  ‚Üí try whisper-small for accents: VOICE_MODEL=small bash scripts/voice-pro"
yellow "  ‚Üí for Indian English add: --prompt 'your common words'"
echo
echo "If transcript is correct:"
green "  ‚Üí VOICE PIPELINE WORKS ‚ÄĒ now run: bash scripts/voice-pro"
